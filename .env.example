# Safe public values supplied by the Supabase Vercel Marketplace integration.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side aliases used by the authenticated Vercel Function.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Vercel AI Gateway model used for signed-in managed reviews.
AXIOMATE_GATEWAY_MODEL=openai/gpt-5.5

# BYOK OpenAI, OpenRouter, and custom gateway keys are entered in the app and
# kept in memory for the current session. Never commit API keys.

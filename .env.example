# Clerk authentication. Only the publishable key is exposed to Vite.
VITE_CLERK_PUBLISHABLE_KEY=
# The Vercel Marketplace integration supplies this alias automatically.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional: PEM public key for networkless Function verification.
CLERK_JWT_KEY=
# Comma-separated additional app origins, if any.
CLERK_AUTHORIZED_PARTIES=https://axiomate-delta.vercel.app

# Neon Postgres server connection. Never expose this as a VITE_ value.
DATABASE_URL=
AXIOMATE_TEX_SNAPSHOT_ID=

# Vercel AI Gateway model used for signed-in managed reviews.
AXIOMATE_GATEWAY_MODEL=google/gemini-2.5-flash-lite

# BYOK OpenAI, OpenRouter, and custom gateway keys are entered in the app and
# kept in memory for the current session. Never commit API keys.
